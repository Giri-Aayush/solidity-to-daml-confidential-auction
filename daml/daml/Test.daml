-- | Daml Script tests for the Confidential Auction (DvP version).
--
-- The headline test, `privacyAndSettlement`, proves on a running ledger that a
-- bidder sees exactly their own bid and nothing else, and that settlement moves
-- real funds atomically: the winner pays the beneficiary while losers are
-- refunded, all in one transaction.
module Test where

import ConfidentialAuction
import Daml.Script
import DA.Assert ((===))
import DA.Time (addRelTime, hours)

-- Issue a holding to each party from the operator (the auctioneer plays the
-- registry role in this self-contained sample).
fund : Party -> Party -> Decimal -> Script (ContractId Holding)
fund operator owner amount =
  submit operator do createCmd Holding with issuer = operator, owner, amount

-- | Sealed bids stay private; settlement is an atomic DvP that pays the
-- beneficiary from the winner and refunds the losers.
privacyAndSettlement : Script ()
privacyAndSettlement = script do
  auctioneer <- allocateParty "Auctioneer"
  seller <- allocateParty "Seller"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  carol <- allocateParty "Carol"
  now <- getTime

  aliceFunds <- fund auctioneer alice 30.0
  bobFunds <- fund auctioneer bob 50.0
  carolFunds <- fund auctioneer carol 40.0

  auctionCid <- submit auctioneer do
    createCmd Auction with
      auctioneer
      auctionId = "PAINTING-2026"
      item = "Rare painting"
      beneficiary = seller
      invited = [alice, bob, carol]
      settleBy = addRelTime now (hours 24)
      biddingOpen = True

  -- Each bidder seals a bid and locks the amount from their holding.
  aliceBid <- submit alice do exerciseCmd auctionCid PlaceBid with bidder = alice, amount = 30.0, funds = aliceFunds
  bobBid <- submit bob do exerciseCmd auctionCid PlaceBid with bidder = bob, amount = 50.0, funds = bobFunds
  carolBid <- submit carol do exerciseCmd auctionCid PlaceBid with bidder = carol, amount = 40.0, funds = carolFunds

  -- Privacy: each bidder sees exactly their OWN bid, by content not just count.
  aliceView <- query @Bid alice
  case aliceView of
    [(_, bid)] -> do
      bid.bidder === alice
      bid.amount === 30.0
    _ -> abort ("Alice must see exactly her own bid; saw " <> show (length aliceView))
  auctioneerView <- query @Bid auctioneer
  length auctioneerView === 3

  -- Close bidding, then settle.
  closedCid <- submit auctioneer do exerciseCmd auctionCid CloseBidding
  resultCid <- submit auctioneer do
    exerciseCmd closedCid Settle with bidCids = [aliceBid, bobBid, carolBid]

  Some result <- queryContractId auctioneer resultCid
  result.winner === bob
  result.winningAmount === 50.0

  -- All bids were cleared.
  remaining <- query @Bid auctioneer
  length remaining === 0

  -- DvP outcome: the seller received the winning 50; the losers were refunded
  -- their own locked amounts; the winner's funds are gone (paid to the seller).
  sellerFunds <- query @Holding seller
  map (\(_, h) -> h.amount) sellerFunds === [50.0]
  aliceRefund <- query @Holding alice
  map (\(_, h) -> h.amount) aliceRefund === [30.0]
  carolRefund <- query @Holding carol
  map (\(_, h) -> h.amount) carolRefund === [40.0]
  bobFundsAfter <- query @Holding bob
  bobFundsAfter === []

  -- Outcome is need-to-know: the winner sees it, neither loser does.
  bobResult <- query @AuctionResult bob
  length bobResult === 1
  aliceResult <- query @AuctionResult alice
  length aliceResult === 0
  carolResult <- query @AuctionResult carol
  length carolResult === 0

  pure ()

-- | A party who was not invited cannot bid.
nonInvitedCannotBid : Script ()
nonInvitedCannotBid = script do
  auctioneer <- allocateParty "Auctioneer"
  seller <- allocateParty "Seller"
  alice <- allocateParty "Alice"
  mallory <- allocateParty "Mallory"
  now <- getTime

  malloryFunds <- fund auctioneer mallory 999.0
  auctionCid <- submit auctioneer do
    createCmd Auction with
      auctioneer
      auctionId = "PAINTING-2026"
      item = "Rare painting"
      beneficiary = seller
      invited = [alice]
      settleBy = addRelTime now (hours 24)
      biddingOpen = True

  mallory `submitMustFail` exerciseCmd auctionCid PlaceBid with bidder = mallory, amount = 999.0, funds = malloryFunds

-- | Once the auctioneer closes bidding, late bids are rejected.
closedBiddingRejectsLateBids : Script ()
closedBiddingRejectsLateBids = script do
  auctioneer <- allocateParty "Auctioneer"
  seller <- allocateParty "Seller"
  alice <- allocateParty "Alice"
  now <- getTime

  aliceFunds <- fund auctioneer alice 10.0
  auctionCid <- submit auctioneer do
    createCmd Auction with
      auctioneer
      auctionId = "PAINTING-2026"
      item = "Rare painting"
      beneficiary = seller
      invited = [alice]
      settleBy = addRelTime now (hours 24)
      biddingOpen = True

  closedCid <- submit auctioneer do exerciseCmd auctionCid CloseBidding
  alice `submitMustFail` exerciseCmd closedCid PlaceBid with bidder = alice, amount = 10.0, funds = aliceFunds

-- | Settlement is refused while bidding is still open.
cannotSettleWhileOpen : Script ()
cannotSettleWhileOpen = script do
  auctioneer <- allocateParty "Auctioneer"
  seller <- allocateParty "Seller"
  alice <- allocateParty "Alice"
  now <- getTime

  aliceFunds <- fund auctioneer alice 10.0
  auctionCid <- submit auctioneer do
    createCmd Auction with
      auctioneer
      auctionId = "PAINTING-2026"
      item = "Rare painting"
      beneficiary = seller
      invited = [alice]
      settleBy = addRelTime now (hours 24)
      biddingOpen = True

  aliceBid <- submit alice do exerciseCmd auctionCid PlaceBid with bidder = alice, amount = 10.0, funds = aliceFunds
  auctioneer `submitMustFail` exerciseCmd auctionCid Settle with bidCids = [aliceBid]

-- | Settlement after the deadline is rejected (time-bounded DvP).
settlementRespectsDeadline : Script ()
settlementRespectsDeadline = script do
  auctioneer <- allocateParty "Auctioneer"
  seller <- allocateParty "Seller"
  alice <- allocateParty "Alice"
  now <- getTime

  aliceFunds <- fund auctioneer alice 10.0
  auctionCid <- submit auctioneer do
    createCmd Auction with
      auctioneer
      auctionId = "PAINTING-2026"
      item = "Rare painting"
      beneficiary = seller
      invited = [alice]
      settleBy = addRelTime now (hours 1)
      biddingOpen = True

  aliceBid <- submit alice do exerciseCmd auctionCid PlaceBid with bidder = alice, amount = 10.0, funds = aliceFunds
  closedCid <- submit auctioneer do exerciseCmd auctionCid CloseBidding

  passTime (hours 2) -- advance past settleBy
  auctioneer `submitMustFail` exerciseCmd closedCid Settle with bidCids = [aliceBid]
