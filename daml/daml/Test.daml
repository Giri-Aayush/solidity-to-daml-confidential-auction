-- | Daml Script tests for the Confidential Auction (token-standard DvP version).
--
-- The headline test, `privacyAndSettlement`, proves on a running ledger that a
-- bidder sees exactly their own bid and nothing else, and that settlement moves
-- real funds atomically through the CIP-0056 `Allocation` interface: the winner
-- pays the beneficiary while losers are refunded, all in one transaction.
--
-- Reads like a Foundry test suite, if you know one: each `Script` is a test
-- function; `submit p cmd` is a transaction sent as party `p` (roughly
-- `vm.prank(p)` plus the call); `submitMustFail` is `vm.expectRevert`;
-- `allocateParty` mints a fresh party (an address you control); and `query @T p`
-- reads exactly what party `p` is allowed to see on the ledger.
module Test where

import ConfidentialAuction
import Daml.Script
import DA.Assert ((===))
import DA.Time (addRelTime, hours)

-- Issue a token-standard holding to a party. The auctioneer plays the registry
-- role in this self-contained sample, so it is the issuer.
fund : Party -> Party -> Decimal -> Script (ContractId AuctionCoin)
fund registry owner amount =
  submit registry do createCmd AuctionCoin with registry, owner, amount, locked = False

-- Create the split auction: the public, roster-free `AuctionTerms` plus the private
-- `AuctionRoster` (which only the auctioneer ever sees). Returns both cids.
mkAuction : Party -> Party -> [Party] -> Time -> Script (ContractId AuctionTerms, ContractId AuctionRoster)
mkAuction auctioneer beneficiary invited settleBy = do
  terms <- submit auctioneer do
    createCmd AuctionTerms with
      auctioneer
      auctionId = "PAINTING-2026"
      item = "Rare painting"
      beneficiary
      settleBy
      biddingOpen = True
  roster <- submit auctioneer do
    createCmd AuctionRoster with auctioneer, auctionId = "PAINTING-2026", invited
  pure (terms, roster)

-- Issue an invited bidder their single-use right to bid (off the private roster).
invite : Party -> ContractId AuctionRoster -> Party -> Script (ContractId BidRight)
invite auctioneer roster bidder =
  submit auctioneer do exerciseCmd roster IssueBidRight with bidder

-- Place a bid: the auctioneer discloses the roster-free terms to the bidder, who then
-- spends their own `BidRight`. The bidder never sees a contract carrying the roster.
placeBid : Party -> ContractId AuctionTerms -> Party -> ContractId BidRight -> Decimal -> ContractId AuctionCoin -> Script (ContractId Bid)
placeBid auctioneer terms bidder right amount funds = do
  Some disc <- queryDisclosure auctioneer terms
  submit (actAs bidder <> disclose disc) do
    exerciseCmd right PlaceBid with terms, amount, funds

-- | Sealed bids stay private; settlement is an atomic DvP that pays the
-- beneficiary from the winner and refunds the losers. The roster stays private too.
privacyAndSettlement : Script ()
privacyAndSettlement = script do
  auctioneer <- allocateParty "Auctioneer"
  seller <- allocateParty "Seller"
  alice <- allocateParty "Alice"
  bob <- allocateParty "Bob"
  carol <- allocateParty "Carol"
  now <- getTime

  aliceFunds <- fund auctioneer alice 30.0
  bobFunds <- fund auctioneer bob 50.0
  carolFunds <- fund auctioneer carol 40.0

  (terms, roster) <- mkAuction auctioneer seller [alice, bob, carol] (addRelTime now (hours 24))

  aliceRight <- invite auctioneer roster alice
  bobRight <- invite auctioneer roster bob
  carolRight <- invite auctioneer roster carol

  -- A15: each bidder sees only their OWN invitation, never the roster, the terms as a
  -- stakeholder, or each other's rights. (Checked before bidding consumes the rights.)
  aliceRights <- query @BidRight alice
  map (\(_, br) -> br.bidder) aliceRights === [alice]
  aliceRoster <- query @AuctionRoster alice
  aliceRoster === []
  aliceTermsView <- query @AuctionTerms alice
  aliceTermsView === []

  -- Each bidder seals a bid and locks the amount as a standard Allocation.
  aliceBid <- placeBid auctioneer terms alice aliceRight 30.0 aliceFunds
  bobBid <- placeBid auctioneer terms bob bobRight 50.0 bobFunds
  carolBid <- placeBid auctioneer terms carol carolRight 40.0 carolFunds

  -- Privacy: each bidder sees exactly their OWN bid, by content not just count.
  aliceView <- query @Bid alice
  case aliceView of
    [(_, bid)] -> do
      bid.bidder === alice
      bid.amount === 30.0
    _ -> abort ("Alice must see exactly her own bid; saw " <> show (length aliceView))
  auctioneerView <- query @Bid auctioneer
  length auctioneerView === 3

  -- Close bidding, then settle (passing the private roster).
  closedTerms <- submit auctioneer do exerciseCmd terms CloseBidding
  resultCid <- submit auctioneer do
    exerciseCmd closedTerms Settle with bidCids = [aliceBid, bobBid, carolBid]; roster

  Some result <- queryContractId auctioneer resultCid
  result.winner === bob
  result.winningAmount === 50.0

  -- All bids were cleared.
  remaining <- query @Bid auctioneer
  length remaining === 0

  -- DvP outcome: the seller received the winning 50; the losers were refunded
  -- their own locked amounts; the winner's funds are gone (paid to the seller).
  sellerFunds <- query @AuctionCoin seller
  map (\(_, c) -> c.amount) sellerFunds === [50.0]
  aliceRefund <- query @AuctionCoin alice
  map (\(_, c) -> c.amount) aliceRefund === [30.0]
  carolRefund <- query @AuctionCoin carol
  map (\(_, c) -> c.amount) carolRefund === [40.0]
  bobFundsAfter <- query @AuctionCoin bob
  bobFundsAfter === []

  -- Outcome is need-to-know: the winner sees it, neither loser does.
  bobResult <- query @AuctionResult bob
  length bobResult === 1
  aliceResult <- query @AuctionResult alice
  length aliceResult === 0
  carolResult <- query @AuctionResult carol
  length carolResult === 0

  pure ()

-- | One bid per *right* is enforced on-ledger: the single-use `BidRight` is
-- consumed by the first bid, so a second bid has no right left to spend. And one
-- bid per *bidder* is enforced at settlement: even if the auctioneer mints a
-- second right for the same party, `Settle` refuses to count both bids (A8).
oneBidPerBidder : Script ()
oneBidPerBidder = script do
  auctioneer <- allocateParty "Auctioneer"
  seller <- allocateParty "Seller"
  alice <- allocateParty "Alice"
  now <- getTime

  firstFunds <- fund auctioneer alice 30.0
  secondFunds <- fund auctioneer alice 30.0
  (terms, roster) <- mkAuction auctioneer seller [alice] (addRelTime now (hours 24))

  aliceRight <- invite auctioneer roster alice
  -- First bid consumes the right.
  firstBid <- placeBid auctioneer terms alice aliceRight 20.0 firstFunds
  -- Reusing the now-spent right is rejected by the ledger (one bid per right).
  Some disc <- queryDisclosure auctioneer terms
  (actAs alice <> disclose disc) `submitMustFail`
    exerciseCmd aliceRight PlaceBid with terms, amount = 25.0, funds = secondFunds

  -- The auctioneer CAN mint a second right for the same bidder (IssueBidRight does
  -- not prevent it), so Alice places a second, distinct bid.
  aliceRight2 <- invite auctioneer roster alice
  secondBid <- placeBid auctioneer terms alice aliceRight2 25.0 secondFunds
  -- But settlement refuses to count two bids from one bidder.
  closedTerms <- submit auctioneer do exerciseCmd terms CloseBidding
  auctioneer `submitMustFail`
    exerciseCmd closedTerms Settle with bidCids = [firstBid, secondBid]; roster

-- | A party who was not invited cannot get a right, nor bid with someone else's.
nonInvitedCannotBid : Script ()
nonInvitedCannotBid = script do
  auctioneer <- allocateParty "Auctioneer"
  seller <- allocateParty "Seller"
  alice <- allocateParty "Alice"
  mallory <- allocateParty "Mallory"
  now <- getTime

  malloryFunds <- fund auctioneer mallory 999.0
  (terms, roster) <- mkAuction auctioneer seller [alice] (addRelTime now (hours 24))

  -- A non-invited party cannot be issued a right (the roster gates issuance).
  auctioneer `submitMustFail` exerciseCmd roster IssueBidRight with bidder = mallory
  -- Even handed an invited bidder's right, a non-invited party cannot bid: PlaceBid
  -- is controlled by the right's named bidder, so Mallory is not the controller.
  aliceRight <- invite auctioneer roster alice
  Some discT <- queryDisclosure auctioneer terms
  Some discR <- queryDisclosure auctioneer aliceRight
  (actAs mallory <> disclose discT <> disclose discR) `submitMustFail`
    exerciseCmd aliceRight PlaceBid with terms, amount = 999.0, funds = malloryFunds

-- | Once the auctioneer closes bidding, late bids are rejected.
closedBiddingRejectsLateBids : Script ()
closedBiddingRejectsLateBids = script do
  auctioneer <- allocateParty "Auctioneer"
  seller <- allocateParty "Seller"
  alice <- allocateParty "Alice"
  now <- getTime

  aliceFunds <- fund auctioneer alice 10.0
  (terms, roster) <- mkAuction auctioneer seller [alice] (addRelTime now (hours 24))

  aliceRight <- invite auctioneer roster alice
  closedTerms <- submit auctioneer do exerciseCmd terms CloseBidding
  Some disc <- queryDisclosure auctioneer closedTerms
  (actAs alice <> disclose disc) `submitMustFail`
    exerciseCmd aliceRight PlaceBid with terms = closedTerms, amount = 10.0, funds = aliceFunds

-- | Settlement is refused while bidding is still open.
cannotSettleWhileOpen : Script ()
cannotSettleWhileOpen = script do
  auctioneer <- allocateParty "Auctioneer"
  seller <- allocateParty "Seller"
  alice <- allocateParty "Alice"
  now <- getTime

  aliceFunds <- fund auctioneer alice 10.0
  (terms, roster) <- mkAuction auctioneer seller [alice] (addRelTime now (hours 24))

  aliceRight <- invite auctioneer roster alice
  aliceBid <- placeBid auctioneer terms alice aliceRight 10.0 aliceFunds
  auctioneer `submitMustFail` exerciseCmd terms Settle with bidCids = [aliceBid]; roster

-- | Settlement after the deadline is rejected (time-bounded DvP).
settlementRespectsDeadline : Script ()
settlementRespectsDeadline = script do
  auctioneer <- allocateParty "Auctioneer"
  seller <- allocateParty "Seller"
  alice <- allocateParty "Alice"
  now <- getTime

  aliceFunds <- fund auctioneer alice 10.0
  (terms, roster) <- mkAuction auctioneer seller [alice] (addRelTime now (hours 1))

  aliceRight <- invite auctioneer roster alice
  aliceBid <- placeBid auctioneer terms alice aliceRight 10.0 aliceFunds
  closedTerms <- submit auctioneer do exerciseCmd terms CloseBidding

  passTime (hours 2) -- advance past settleBy
  auctioneer `submitMustFail` exerciseCmd closedTerms Settle with bidCids = [aliceBid]; roster

-- | Explicit disclosure: a party who is not a stakeholder can still use a contract as
-- a command input if it is disclosed to them. Here a prospective bidder reads the
-- public terms without being an observer (and the roster stays hidden regardless).
explicitDisclosure : Script ()
explicitDisclosure = script do
  auctioneer <- allocateParty "Auctioneer"
  seller <- allocateParty "Seller"
  alice <- allocateParty "Alice"
  dave <- allocateParty "Dave" -- a prospective bidder, not invited, not an observer
  now <- getTime

  (terms, _roster) <- mkAuction auctioneer seller [alice] (addRelTime now (hours 24))

  -- Dave is not a stakeholder, so the terms are not on his ledger at all.
  daveSees <- query @AuctionTerms dave
  daveSees === []
  -- Without the contract, Dave cannot reference it in a command.
  dave `submitMustFail` exerciseCmd terms FetchTerms with viewer = dave

  -- The auctioneer discloses the terms; now Dave can read them using the disclosed
  -- contract, still without becoming a stakeholder.
  Some disclosed <- queryDisclosure auctioneer terms
  (item, _) <- submit (actAs dave <> disclose disclosed) do
    exerciseCmd terms FetchTerms with viewer = dave
  item === "Rare painting"

  stillHidden <- query @AuctionTerms dave
  stillHidden === []

-- | Liveness: once the settlement deadline passes, a bidder can reclaim their own
-- locked funds without the auctioneer, and only the bidder can. Before the deadline,
-- and for anyone other than the bidder, reclaim is refused.
deadlineReclaim : Script ()
deadlineReclaim = script do
  auctioneer <- allocateParty "Auctioneer"
  seller <- allocateParty "Seller"
  alice <- allocateParty "Alice"
  now <- getTime

  aliceFunds <- fund auctioneer alice 30.0
  (terms, roster) <- mkAuction auctioneer seller [alice] (addRelTime now (hours 1))

  aliceRight <- invite auctioneer roster alice
  aliceBid <- placeBid auctioneer terms alice aliceRight 30.0 aliceFunds

  -- Her 30 is locked behind the allocation; she holds no free coin right now.
  locked <- query @AuctionCoin alice
  map (\(_, c) -> (c.amount, c.locked)) locked === [(30.0, True)]

  -- Before the deadline, reclaim is refused: settlement is still the auctioneer's.
  alice `submitMustFail` exerciseCmd aliceBid ReclaimAfterDeadline

  passTime (hours 2) -- advance past settleBy

  -- The auctioneer cannot reclaim on the bidder's behalf (controller is the bidder).
  auctioneer `submitMustFail` exerciseCmd aliceBid ReclaimAfterDeadline

  -- The bidder reclaims her own funds, no auctioneer involved.
  _ <- submit alice do exerciseCmd aliceBid ReclaimAfterDeadline

  -- The bid is gone and her funds are back, unlocked.
  remaining <- query @Bid alice
  remaining === []
  refunded <- query @AuctionCoin alice
  map (\(_, c) -> (c.amount, c.locked)) refunded === [(30.0, False)]
